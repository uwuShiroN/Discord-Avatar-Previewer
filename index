let currentLang='mixed';
function applyLang(lang){
  currentLang=lang;
  const t=LANGS[lang];
  document.querySelectorAll('#langSeg .seg-btn').forEach(b=>b.classList.toggle('active',b.dataset.lang===lang));
  Object.entries(t).forEach(([id,val])=>{
    const el=document.getElementById(id);
    if(!el)return;
    if(id.startsWith('you-name-')){el.childNodes[0].textContent=val;return;}
    el.innerHTML=val;
  });
}
document.querySelectorAll('#langSeg .seg-btn').forEach(b=>{
  b.addEventListener('click',()=>applyLang(b.dataset.lang));
});

const themeToggleBtn=document.getElementById('themeToggleBtn');
const themeIcon=document.getElementById('themeIcon');
let lightMode=false;
themeToggleBtn.addEventListener('click',()=>{
  lightMode=!lightMode;
  document.documentElement.classList.toggle('light',lightMode);
  if(lightMode){
    themeIcon.className='ti ti-sun';
    themeToggleBtn.title='Toggle dark mode';
  }else{
    themeIcon.className='ti ti-moon';
    themeToggleBtn.title='Toggle light mode';
  }
});

const panel=document.getElementById('resizablePanel');
const rHandle=document.getElementById('resizeHandle');
let rDragging=false,rStartX=0,rStartW=0;
rHandle.addEventListener('mousedown',e=>{rDragging=true;rStartX=e.clientX;rStartW=panel.offsetWidth;rHandle.classList.add('dragging');e.preventDefault();});
document.addEventListener('mousemove',e=>{
  if(!rDragging)return;
  const newW=Math.min(520,Math.max(220,rStartW+(e.clientX-rStartX)));
  panel.style.width=newW+'px';
  document.documentElement.style.setProperty('--panel-width',newW+'px');
  updateBox();
});
document.addEventListener('mouseup',()=>{rDragging=false;rHandle.classList.remove('dragging');});

const fileInput=document.getElementById('fileInput');
const uploadZone=document.getElementById('uploadZone');
const cropSec=document.getElementById('cropSec');
const sc=document.getElementById('sc');
const cw=document.getElementById('cw');
const cb=document.getElementById('cb');
const rh=document.getElementById('rh');
const csSlider=document.getElementById('csSlider');
const csVal=document.getElementById('csVal');
const resetBtn=document.getElementById('resetBtn');
const dlBtn=document.getElementById('dlBtn');
const avSlider=document.getElementById('avSlider');
const avVal=document.getElementById('avVal');

let img=null;
let cx=0,cy=0,cs=100;
let isDragging=false,isResizing=false;
let dx0=0,dy0=0,cx0=0,cy0=0,cs0=0;

const MY_AVIDS=['dav1','dav2'];
const PREV_SIZES={pv80:72,pv40:40,pv24:24};

function initAvatarImages(src){
  MY_AVIDS.forEach(id=>{
    const el=document.getElementById(id);
    el.innerHTML=`<img src="${src}" id="${id}_img" alt="avatar" style="position:absolute;top:0;left:0;transform-origin:0 0;will-change:transform;">`;
  });
  Object.keys(PREV_SIZES).forEach(id=>{
    const el=document.getElementById(id);
    el.innerHTML=`<img src="${src}" id="${id}_img" alt="avatar" style="position:absolute;top:0;left:0;transform-origin:0 0;will-change:transform;">`;
  });
}

function syncPreviews(){
  if(!img)return;
  MY_AVIDS.forEach(id=>{
    const el=document.getElementById(id);
    const imgEl=document.getElementById(id+'_img');
    if(!imgEl)return;
    const targetSize=parseFloat(el.style.width)||40;
    const s=targetSize/cs;
    imgEl.style.width=img.naturalWidth+'px';
    imgEl.style.height=img.naturalHeight+'px';
    imgEl.style.transform=`translate(${-cx*s}px,${-cy*s}px) scale(${s})`;
  });
  Object.entries(PREV_SIZES).forEach(([id,targetSize])=>{
    const imgEl=document.getElementById(id+'_img');
    if(!imgEl)return;
    const s=targetSize/cs;
    imgEl.style.width=img.naturalWidth+'px';
    imgEl.style.height=img.naturalHeight+'px';
    imgEl.style.transform=`translate(${-cx*s}px,${-cy*s}px) scale(${s})`;
  });
}

function updateSliderFill(slider){
  const min=+slider.min,max=+slider.max,val=+slider.value;
  const pct=((val-min)/(max-min)*100).toFixed(1)+'%';
  slider.style.setProperty('--pct',pct);
}
[csSlider,avSlider].forEach(s=>s.addEventListener('input',()=>updateSliderFill(s)));
[csSlider,avSlider].forEach(s=>updateSliderFill(s));

function applyScaleChat(s){
  const body=document.getElementById('dcBody');
  const ratio=s/40;
  body.style.transform=`scale(${ratio})`;
  body.style.transformOrigin='top left';
  body.style.width=(100/ratio)+'%';
}

avSlider.addEventListener('input',()=>{
  const s=+avSlider.value;
  avVal.textContent=s+'px';
  applyScaleChat(s);
});

uploadZone.addEventListener('click',()=>fileInput.click());
fileInput.addEventListener('change',e=>{
  const f=e.target.files[0];if(!f)return;
  const r=new FileReader();
  r.onload=ev=>loadImage(ev.target.result);
  r.readAsDataURL(f);
});

function loadImage(src){
  img=new Image();
  img.onload=()=>{
    sc.width=img.naturalWidth;
    sc.height=img.naturalHeight;
    const ctx=sc.getContext('2d');
    ctx.clearRect(0,0,sc.width,sc.height);
    ctx.drawImage(img,0,0);

    cs=Math.min(Math.round(img.naturalWidth*.65),Math.round(img.naturalHeight*.65));
    cx=Math.round((img.naturalWidth-cs)/2);
    cy=Math.round((img.naturalHeight-cs)/2);

    csSlider.min=20;
    csSlider.max=Math.min(img.naturalWidth,img.naturalHeight);
    csSlider.value=cs;
    csVal.textContent=cs+'px';
    updateSliderFill(csSlider);

    initAvatarImages(src);

    uploadZone.style.display='none';
    cropSec.style.display='flex';
    applyScaleChat(+avSlider.value);

    // 核心修正：利用 requestAnimationFrame 延遲一幀執行 updateBox()
    // 確保瀏覽器已經完成 DOM 的 display 切換與排版，讓 sc.offsetWidth 能拿到正確的寬度
    requestAnimationFrame(()=>{
      updateBox();
    });
  };
  img.src=src;
}

function getVisScale(){
  // 如果 sc.offsetWidth 尚未準備好，回傳一個安全的基本縮放比，避免除以 0 歪掉
  if(!sc.offsetWidth||!img) return 1;
  return sc.offsetWidth/img.naturalWidth;
}

function updateBox(){
  if(!img)return;
  const vs=getVisScale();
  cb.style.left=(cx*vs)+'px';
  cb.style.top=(cy*vs)+'px';
  cb.style.width=(cs*vs)+'px';
  cb.style.height=(cs*vs)+'px';
  syncPreviews();
}

csSlider.addEventListener('input',()=>{
  const newCs=+csSlider.value;
  const centerX=cx+cs/2,centerY=cy+cs/2;
  let newCx=centerX-newCs/2,newCy=centerY-newCs/2;
  newCx=Math.max(0,Math.min(newCx,img.naturalWidth-newCs));
  newCy=Math.max(0,Math.min(newCy,img.naturalHeight-newCs));
  cs=newCs;cx=newCx;cy=newCy;
  csVal.textContent=Math.round(cs)+'px';
  updateBox();
});

cb.addEventListener('mousedown',e=>{
  if(e.target===rh)return;
  isDragging=true;dx0=e.clientX;dy0=e.clientY;cx0=cx;cy0=cy;e.preventDefault();
});
rh.addEventListener('mousedown',e=>{
  isResizing=true;dx0=e.clientX;dy0=e.clientY;cx0=cx;cy0=cy;cs0=cs;e.stopPropagation();e.preventDefault();
});
cb.addEventListener('touchstart',e=>{
  if(e.target===rh)return;
  isDragging=true;dx0=e.touches[0].clientX;dy0=e.touches[0].clientY;cx0=cx;cy0=cy;e.preventDefault();
},{passive:false});
rh.addEventListener('touchstart',e=>{
  isResizing=true;dx0=e.touches[0].clientX;dy0=e.touches[0].clientY;cx0=cx;cy0=cy;cs0=cs;e.stopPropagation();e.preventDefault();
},{passive:false});

function onMove(px,py){
  const vs=getVisScale();
  if(isDragging){
    cx=Math.max(0,Math.min(cx0+(px-dx0)/vs,img.naturalWidth-cs));
    cy=Math.max(0,Math.min(cy0+(py-dy0)/vs,img.naturalHeight-cs));
    updateBox();
  } else if(isResizing){
    const deltaX=(px-dx0)/vs,deltaY=(py-dy0)/vs;
    const delta=Math.max(deltaX,deltaY);
    let newCs=cs0+delta*2;
    const centerX=cx0+cs0/2,centerY=cy0+cs0/2;
    const maxAvail=Math.min(centerX*2,centerY*2,(img.naturalWidth-centerX)*2,(img.naturalHeight-centerY)*2);
    newCs=Math.max(20,Math.min(newCs,maxAvail));
    const newCx=centerX-newCs/2,newCy=centerY-newCs/2;
    cs=newCs;cx=newCx;cy=newCy;
    csSlider.value=Math.round(cs);csVal.textContent=Math.round(cs)+'px';updateSliderFill(csSlider);
    updateBox();
  }
}
document.addEventListener('mousemove',e=>{if(isDragging||isResizing)onMove(e.clientX,e.clientY);});
document.addEventListener('touchmove',e=>{if(isDragging||isResizing){onMove(e.touches[0].clientX,e.touches[0].clientY);e.preventDefault();}},{passive:false});
document.addEventListener('mouseup',()=>{isDragging=false;isResizing=false;});
document.addEventListener('touchend',()=>{isDragging=false;isResizing=false;});

dlBtn.addEventListener('click',()=>{
  if(!img)return;
  const out=document.createElement('canvas');
  const sz=512;out.width=sz;out.height=sz;
  const ctx=out.getContext('2d');
  ctx.beginPath();ctx.arc(sz/2,sz/2,sz/2,0,Math.PI*2);ctx.clip();
  ctx.drawImage(img,
    Math.round(cx),Math.round(cy),
    Math.round(cs),Math.round(cs),
    0,0,sz,sz
  );
  const a=document.createElement('a');
  a.href=out.toDataURL('image/png');
  a.download='avatar.png';a.click();
});

resetBtn.addEventListener('click',()=>{
  uploadZone.style.display='';
  cropSec.style.display='none';
  fileInput.value='';img=null;
  MY_AVIDS.forEach(id=>{
    document.getElementById(id).innerHTML='<i class="ti ti-user" style="font-size:18px;color:#fff"></i>';
  });
  [{id:'pv80',fs:30},{id:'pv40',fs:18},{id:'pv24',fs:11}].forEach(({id,fs})=>{
    document.getElementById(id).innerHTML=`<i class="ti ti-user" style="font-size:${fs}px;color:#fff"></i>`;
  });
  avSlider.value=40;avVal.textContent='40px';updateSliderFill(avSlider);
  applyScaleChat(40);
});

window.addEventListener('resize',()=>{if(img)updateBox();});
</script>
</body>
