<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Discord Avatar Preview v1</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<style>
:root{
  --bg:#1e1f22;--sidebar:#2b2d31;--chat:#313338;--input-bg:#383a40;
  --border:#1e1f22;--muted:#80848e;--text:#dbdee1;--heading:#f2f3f5;
  --blurple:#5865f2;--blurple-h:#4752c4;--green:#3ba55c;--red:#ed4245;
  --card:#313338;--divider:#3f4147;
  --track:#4e5058;--track-fill:#5865f2;
  --sl-thumb:#fff;--sl-track:#4e5058;
  --btn-sec:#313338;--btn-sec-t:#b5bac1;
  --msg-hover:rgba(4,4,5,.07);
  --panel-width:320px;
}
.light{
  --bg:#f2f3f5;--sidebar:#e3e5e8;--chat:#ffffff;--input-bg:#e0e2e5;
  --border:#d4d7dc;--muted:#4e5058;--text:#2e3338;--heading:#060607;
  --card:#ffffff;--divider:#c4c9d0;
  --track:#c4c9d0;--track-fill:#5865f2;
  --sl-thumb:#fff;--sl-track:#c4c9d0;
  --btn-sec:#e0e2e5;--btn-sec-t:#4e5058;
  --msg-hover:rgba(6,6,7,.04);
}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{width:100%;height:100%;overflow:hidden;background:var(--bg);font-family:'gg sans','Noto Sans TC',sans-serif;color:var(--text);transition:background .2s,color .2s;}
body{display:flex;flex-direction:column;}

.topbar{height:52px;background:var(--sidebar);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 16px;gap:12px;flex-shrink:0;z-index:10;}
.topbar-dot{width:26px;height:26px;border-radius:50%;background:linear-gradient(135deg,#5865f2,#8892ff);flex-shrink:0;box-shadow:0 0 8px rgba(88,101,242,.4);}
.topbar-title{font-size:15px;font-weight:700;color:var(--heading);}
.topbar-sub{font-size:12px;color:var(--muted);}
.topbar-right{margin-left:auto;display:flex;align-items:center;gap:12px;}
.switch-group{display:flex;align-items:center;gap:6px;}
.switch-label{font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;}
.seg{display:flex;background:var(--bg);border-radius:6px;padding:2px;gap:1px;}
.seg-btn{padding:4px 9px;border:none;background:transparent;color:var(--muted);font-size:11px;font-weight:600;cursor:pointer;border-radius:4px;transition:background .12s,color .12s;white-space:nowrap;}
.seg-btn.active{background:var(--blurple);color:#fff;}
.seg-btn:hover:not(.active){background:var(--divider);color:var(--heading);}

.icon-toggle-btn{background:transparent;border:none;color:var(--muted);font-size:22px;cursor:pointer;display:flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:50%;transition:background .15s,color .15s;}
.icon-toggle-btn:hover{background:var(--divider);color:var(--heading);}

.workspace{display:flex;flex:1;min-height:0;}

.resizable-panel{width:var(--panel-width);min-width:220px;max-width:520px;background:var(--sidebar);display:flex;flex-direction:column;position:relative;overflow:hidden;flex-shrink:0;}
.resize-handle{position:absolute;right:0;top:0;bottom:0;width:5px;cursor:col-resize;background:transparent;z-index:20;transition:background .15s;}
.resize-handle:hover,.resize-handle.dragging{background:var(--blurple);}
.panel-inner{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:12px;min-width:0;}

.sec-label{font-size:11px;font-weight:700;letter-spacing:.07em;color:var(--muted);text-transform:uppercase;margin-bottom:6px;}
.divider{height:0.5px;background:var(--divider);}

.upload-zone{border:2px dashed var(--divider);border-radius:10px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:7px;cursor:pointer;padding:28px 12px;min-height:130px;transition:background .15s,border-color .15s;}
.upload-zone:hover{background:var(--chat);border-color:var(--blurple);}
.upload-zone i{font-size:30px;color:var(--muted);}
.upload-zone span{font-size:13px;font-weight:600;color:var(--heading);}
.upload-zone small{font-size:11px;color:var(--muted);}
#fileInput{display:none;}

.crop-section{display:none;flex-direction:column;gap:10px;}

.canvas-outer{position:relative;background:var(--bg);border-radius:10px;overflow:hidden;cursor:crosshair;user-select:none;touch-action:none;}
#sc{display:block;width:100%;height:auto;image-rendering:-webkit-optimize-contrast;image-rendering:high-quality;}
.crop-box{position:absolute;border:2px solid rgba(255,255,255,.88);box-shadow:0 0 0 9999px rgba(0,0,0,.6);border-radius:50%;cursor:move;pointer-events:all;transform:translate3d(0,0,0);}
.light .crop-box{border-color:rgba(0,0,0,.7);box-shadow:0 0 0 9999px rgba(0,0,0,.45);}
.rh{position:absolute;width:13px;height:13px;background:#fff;border-radius:50%;right:-6px;bottom:-6px;cursor:nwse-resize;pointer-events:all;box-shadow:0 1px 4px rgba(0,0,0,.5);}

.slrow{display:flex;align-items:center;gap:8px;}
.slrow label{font-size:12px;color:var(--heading);min-width:56px;}
.slrow .sv{font-size:12px;color:var(--muted);min-width:34px;text-align:right;}
.slrow input[type=range]{-webkit-appearance:none;appearance:none;flex:1;height:20px;background:transparent;cursor:pointer;padding:0;}
.slrow input[type=range]:focus{outline:none;}
.slrow input[type=range]::-webkit-slider-container{display:flex;align-items:center;}
.slrow input[type=range]::-webkit-slider-runnable-track{height:8px;border-radius:4px;background:linear-gradient(to right,var(--track-fill) var(--pct,50%),var(--sl-track) var(--pct,50%));}
.slrow input[type=range]::-moz-range-track{height:8px;border-radius:4px;background:var(--sl-track);}
.slrow input[type=range]::-moz-range-progress{height:8px;border-radius:4px;background:var(--track-fill);}
.slrow input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;appearance:none;width:16px;height:16px;border-radius:50%;background:var(--sl-thumb);box-shadow:0 1px 4px rgba(0,0,0,.35);margin-top:-4px;transition:transform .1s;}
.slrow input[type=range]::-webkit-slider-thumb:hover{transform:scale(1.15);}
.slrow input[type=range]::-moz-range-thumb{width:16px;height:16px;border:none;border-radius:50%;background:var(--sl-thumb);box-shadow:0 1px 4px rgba(0,0,0,.35);}

.btn-row{display:flex;gap:6px;}
.btn-sm{flex:1;padding:8px 10px;background:var(--btn-sec);color:var(--btn-sec-t);border:none;border-radius:7px;font-size:12px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:5px;transition:background .15s,opacity .15s;}
.btn-sm:hover{opacity:.85;}
.btn-dl{background:#1e6b38;color:#fff;}

.prev-strip{display:flex;align-items:flex-end;gap:14px;background:var(--chat);border-radius:10px;padding:12px 14px;}
.pv-item{display:flex;flex-direction:column;align-items:center;gap:5px;}
.pv-item p{font-size:10px;color:var(--muted);}
.av,.dav{border-radius:50%;overflow:hidden;display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative;background:var(--blurple);}
.av img,.dav img{position:absolute;top:0;left:0;transform-origin:0 0;will-change:transform;}

.dc-wrap{flex:1;display:flex;flex-direction:column;min-width:0;background:var(--chat);}
.dc-hd{height:48px;background:var(--chat);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 16px;gap:8px;flex-shrink:0;}
.dc-hd i{font-size:20px;color:var(--muted);}
.dc-ch{font-size:16px;font-weight:700;color:var(--heading);}
.dc-sep{width:1px;height:18px;background:var(--divider);margin:0 4px;}
.dc-topic{font-size:13px;color:var(--muted);}

.chat-viewport{flex:1;overflow:hidden;position:relative;}
.chat-scale{transform-origin:top left;width:100%;padding:8px 0 12px;}
.msg{display:flex;padding:2px 16px;border-radius:2px;}
.msg:hover{background:var(--msg-hover);}
.msg.first{margin-top:14px;}
.msg-av-col{flex-shrink:0;display:flex;justify-content:center;}
.mc{flex:1;min-width:0;padding-left:12px;}
.mh{display:flex;align-items:baseline;gap:8px;margin-bottom:2px;}
.uname{font-size:15px;font-weight:600;color:var(--heading);line-height:1.3;}
.ts{font-size:11px;color:#4e5058;}
.mt{font-size:15px;color:var(--text);line-height:1.55;}
.badge{display:inline-block;background:var(--blurple);color:#fff;font-size:10px;padding:1px 5px;border-radius:3px;margin-left:4px;vertical-align:middle;font-weight:700;}

.dc-inp-area{padding:8px 16px 14px;background:var(--chat);flex-shrink:0;}
.dc-inp{background:var(--input-bg);border-radius:8px;padding:10px 14px;display:flex;align-items:center;gap:8px;color:var(--muted);font-size:14px;}
.dc-inp i{font-size:18px;}

.footer{height:36px;background:var(--sidebar);border-top:1px solid var(--border);display:flex;align-items:center;justify-content:center;gap:8px;font-size:12px;color:var(--muted);flex-shrink:0;}
.footer strong{color:var(--heading);}
</style>
</head>
